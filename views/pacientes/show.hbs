<div class="container mt-4">
  <a href="/affiliates" class="btn btn-link link-secondary text-decoration-none mb-3 p-0">← Volver al listado</a>

  <div class="row">
    <div class="col-md-5">
      <h1 class="h3 mb-3 fw-bold text-dark">{{paciente.firstName}} {{paciente.lastName}}</h1>

      <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
          <p class="mb-2"><strong><i class="bi bi-envelope"></i> Email:</strong> <br><span class="text-muted">{{paciente.email}}</span></p>
          <p class="mb-0"><strong><i class="bi bi-patch-check"></i> Membresía:</strong> <br><span class="badge bg-primary px-3">{{paciente.membershipType}}</span></p>
        </div>
      </div>

      <div class="d-flex gap-2 mb-4">
        <a href="/affiliates/{{paciente.id}}/edit" class="btn btn-warning px-4 shadow-sm fw-bold">Editar Perfil</a>
        <form action="/affiliates/{{paciente.id}}/delete" method="POST" onsubmit="return confirm('¿Está seguro de eliminar este registro?')">
          <button type="submit" class="btn btn-outline-danger px-4 fw-bold">Eliminar</button>
        </form>
      </div>
    </div>

    <div class="col-md-7">
      <!-- SIMULADOR -->
      <div class="card border-0 shadow-sm border-start border-4 border-success">
        <div class="card-header bg-white py-3">
          <h5 class="card-title mb-0 text-success fw-bold">Simulador de presupuesto</h5>
        </div>
        <div class="card-body bg-light">
          <form action="/affiliates/{{paciente.id}}/simular" method="POST">
            <div class="mb-4">
              <label for="montoTratamiento" class="form-label fw-bold">Costo del tratamiento</label>
              <div class="input-group input-group-lg">
                <span class="input-group-text">$</span>
                <input type="text" id="montoTratamiento" name="montoTratamiento" class="form-control px-3 py-2 {{#if errors.montoTratamiento}} is-invalid{{/if}}" placeholder="0" inputmode="decimal" value="{{montoTratamiento}}">
              </div>
              {{#if errors.montoTratamiento}}
                <div class="text-danger mt-1 small">{{errors.montoTratamiento}}</div>
              {{/if}}
              <div class="form-text mt-2">Ingrese el valor total para calcular el beneficio del paciente.</div>
            </div>
            <div class="d-grid mb-4">
              <button type="submit" class="btn btn-success btn-lg fw-bold">Calcular</button>
            </div>
          </form>

          <div class="p-4 bg-white rounded shadow-sm">
            <div class="d-flex justify-content-between align-items-center mb-2">
              <span class="text-muted small">Beneficio ({{paciente.membershipType}})</span>
              <span class="badge bg-success" id="badgeDescuento" data-porcentaje="{{paciente.descuento}}">{{paciente.descuento}}% OFF</span>
            </div>
            <hr class="text-muted opacity-25">
            <div class="d-flex justify-content-between align-items-center mt-3">
              <h4 class="mb-0 fw-bold">Total a pagar:</h4>
              <h4 class="text-primary mb-0 fw-bold" id="resultado">{{#if totalCalculado}}{{totalCalculado}}{{else}}$0{{/if}}</h4>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>